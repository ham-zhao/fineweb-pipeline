# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── 虚拟环境 ─────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── 数据文件（不入库，体积过大）─────────────────────────
data/raw/*.warc.gz
data/raw/*.warc
data/raw/*.parquet
data/gen1_output/*.jsonl
data/gen1_output/**/*.jsonl
data/gen2_output/*.jsonl
data/gen2_output/**/*.jsonl
data/gen3_output/*.jsonl
data/gen3_output/**/*.jsonl
data/*_fineweb_bak/
data/reference/*.jsonl
data/reference/*.parquet
data/reference/fineweb_sample/
data/raw/*.jsonl
data/models/
notebooks/data/

# ── 模型文件 ─────────────────────────────────────────────
# fastText / scikit-learn / PyTorch 模型
*.bin
*.pkl
*.pt
*.pth

# ── 结果文件（图表和报告保留，大文件不保留）────────────
results/proxy_models/*.pt
results/proxy_models/*.pth

# ── API 配置（含密钥，绝对不入库）───────────────────────
# 注意：configs/api_config.yaml 中的 api_key 字段只存占位符
# 实际密钥存环境变量或单独的 .env 文件
.env
.env.local
secrets.yaml

# ── macOS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 日志 ─────────────────────────────────────────────────
*.log
logs/

# ── 临时文件 ─────────────────────────────────────────────
*.tmp
*.temp
tmp/
temp/
